{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Настройка окружения и установка библиотек",
      "type": "shell",
      "osx": {
        "command": "python3 -m venv .venv && .venv/bin/pip install -r backend/requirements.txt"
      },
      "linux": {
        "command": "python3 -m venv .venv && .venv/bin/pip install -r backend/requirements.txt"
      },
      "windows": {
        "command": "python -m venv .venv && .\\.venv\\Scripts\\pip install -r backend\\requirements.txt"
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    }
  ]
}